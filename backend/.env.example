"""
Environment variables template
"""
# App
APP_NAME=Deschain
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://deschain:deschain123@localhost:5432/deschain_db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-with-256-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]

# API
API_V1_PREFIX=/api/v1
API_DOCS_URL=/docs
API_OPENAPI_URL=/openapi.json

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@deschain.id

# Midtrans Payment Gateway
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false

# WhatsApp Integration (Optional)
WHATSAPP_API_URL=https://api.whatsapp.com
WHATSAPP_API_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Redis (Optional)
REDIS_URL=redis://localhost:6379

# AWS S3 (Optional)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET_NAME=deschain-uploads
AWS_S3_REGION=ap-southeast-1

# Feature Flags
ENABLE_AI_MATCHING=true
ENABLE_AUTO_GROUP_FORMATION=true
ENABLE_NOTIFICATION_EMAIL=false
ENABLE_NOTIFICATION_WHATSAPP=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# AI / LLM (pilih salah satu atau keduanya)
GROQ_API_KEY=           # Dapatkan gratis di console.groq.com
ANTHROPIC_API_KEY=      # Dari console.anthropic.com
